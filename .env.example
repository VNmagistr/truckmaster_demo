# ---------------------------------------------------------------
# Мінімальні налаштування для локального запуску (DEBUG=True)
# Скопіюйте цей файл як .env і змініть значення за потреби
# ---------------------------------------------------------------

SECRET_KEY=change-me-to-any-random-string-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# При DEBUG=True база даних — SQLite (файл db.sqlite3), нічого додатково не потрібно.
# Для продакшн (DEBUG=False) потрібен PostgreSQL:
# DB_NAME=truckmaster
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# ---------------------------------------------------------------
# Необов'язкові зовнішні сервіси (можна залишити порожніми)
# Без них відповідні функції просто не працюватимуть
# ---------------------------------------------------------------

# Telegram-бот
TELEGRAM_BOT_TOKEN=

# Nova Poshta API (відстеження відправок)
NP_API_KEY=

# Google Places API (відгуки на головній сторінці)
GOOGLE_PLACES_API_KEY=

# ALPR (розпізнавання номерних знаків)
ALPR_API_KEY=
ALPR_STAFF_CHAT_ID=
